rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Format-level DOB validity — the strongest check Firestore Rules can
    // feasibly do (no generic date-arithmetic/formatting functions exist
    // here, so true age/maturity math stays a client+service-layer
    // concern via lib/utils.ts's parseDobStrict, which this mirrors the
    // shape of). Requires exactly YYYY-MM-DD — catches missing, wrong
    // type, and unparsable/malformed values. A dog whose OWN dateOfBirth
    // fails this can never be accepted as a Sire/Dam reference, even if
    // every ownership/sex check passes — "can't prove maturity" must
    // never resolve to "eligible".
    function isValidDobString(dob) {
      return dob is string && dob.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$');
    }

    function isOwnerUser(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // A dog "belongs to" whoever is its breeder (tenantId) or its current
    // owner (currentOwnerId) — both should be able to see/manage it.
    function dogBelongsToUser(dogId) {
      let dog = get(/databases/$(database)/documents/dogs/$(dogId)).data;
      return isSignedIn() &&
        (dog.tenantId == request.auth.uid || dog.currentOwnerId == request.auth.uid);
    }

    // NOTE: full Sire/Dam breeding-parent eligibility (sex, ownership,
    // deceased, DOB validity, AND actual minimum-age maturity — which
    // needs real date arithmetic this rules language has no functions
    // for) is no longer checked here. isEligibleBreedingDog/
    // isEligibleSire/isEligibleDam/heatCycleSireValid were removed —
    // litters create and heatCycles create/update are now `if false`
    // below and happen exclusively through api/create-litter.js and
    // api/save-heat-cycle.js (Admin SDK, full validation via
    // _lib/parent-eligibility.js). See those files for the canonical
    // policy (Codex round 3, Blocker 1).

    // ── users/{uid} — only the account owner can read/write their own profile ──
    match /users/{userId} {
      allow read, write: if isOwnerUser(userId);
    }

    // ── dogs/{dogId} ──
    // NOTE: if there is a public QR "passport" view of a dog (scan a QR code
    // to see public-safe details without logging in), this rule will BREAK
    // it, because read now requires being the tenant or current owner.
    // Public passport viewing needs to go through a server API route (using
    // Admin SDK, which bypasses these rules) that returns only the fields
    // allowed by PassportVisibility — never a direct client-side Firestore
    // read of the full dog document. Flag this before deploying if such a
    // page exists.
    match /dogs/{dogId} {
      // resource == null guard: createLitterPuppyAtomic() does a tx.get()
      // on a not-yet-created dogId (its idempotency check — "does this
      // dog already exist from a prior retry?") before ever writing it.
      // Without this guard, dereferencing resource.data on a get() of a
      // missing document is a rules runtime error, which Firestore
      // treats as a deny — breaking puppy creation outright, not just
      // relaxing a check. A missing document exposes no data either way.
      // Same pattern already used below for reminders/{id}'s get.
      allow read: if isSignedIn() &&
        (resource == null || resource.data.tenantId == request.auth.uid || resource.data.currentOwnerId == request.auth.uid);

      // Only the CURRENT owner may write — not the former breeder once a
      // claim has moved currentOwnerId elsewhere (tenantId is permanent
      // provenance for *read*, not an ongoing management right). Verified
      // safe: transferDogOwnership() is only ever called while the caller
      // still IS currentOwnerId (currentOwnerId only changes via the
      // server-side claim route), so no legitimate flow needs tenantId-only
      // write access. Also never reassigns tenantId/currentOwnerId/
      // createdByUserId/sourceType — those are immutable via any client
      // write, changed only by the Admin SDK claim route, which bypasses
      // these rules entirely.
      // Ownership-history fields are immutable once set — a dog's
      // transfer/claim record is permanent provenance, never something
      // the current owner (who, post-claim, is the buyer — the very
      // person the history is about) should be able to edit away. Each
      // check only fires once the OLD value is already non-null, so the
      // FIRST write (transferDogOwnership() setting these for the first
      // time, or the Admin SDK claim route setting claimedAt/claimedBy)
      // remains allowed — only a later attempt to change or clear an
      // already-set value is blocked. buyerPhone is deliberately left
      // out: a contact-detail typo fix isn't a history-tampering risk
      // the way erasing buyerEmail/transferredAt/previousOwnerId/
      // claimedAt/claimedBy would be.
      allow update: if isSignedIn() &&
        resource.data.currentOwnerId == request.auth.uid &&
        request.resource.data.tenantId == resource.data.tenantId &&
        request.resource.data.currentOwnerId == resource.data.currentOwnerId &&
        request.resource.data.createdByUserId == resource.data.createdByUserId &&
        request.resource.data.sourceType == resource.data.sourceType &&
        (resource.data.get('buyerEmail', null) == null ||
         request.resource.data.get('buyerEmail', null) == resource.data.get('buyerEmail', null)) &&
        (resource.data.get('buyerName', null) == null ||
         request.resource.data.get('buyerName', null) == resource.data.get('buyerName', null)) &&
        (resource.data.get('transferredAt', null) == null ||
         request.resource.data.get('transferredAt', null) == resource.data.get('transferredAt', null)) &&
        (resource.data.get('previousOwnerId', null) == null ||
         request.resource.data.get('previousOwnerId', null) == resource.data.get('previousOwnerId', null)) &&
        (resource.data.get('claimedAt', null) == null ||
         request.resource.data.get('claimedAt', null) == resource.data.get('claimedAt', null)) &&
        (resource.data.get('claimedBy', null) == null ||
         request.resource.data.get('claimedBy', null) == resource.data.get('claimedBy', null));

      // A dog mid-transfer (marked 'transferred'/'pendingClaim' by
      // transferDogOwnership(), currentOwnerId not yet moved) can never
      // be deleted by the outgoing breeder — a real commercial
      // transaction (possibly with a deposit already taken) may be in
      // progress. Checks both the current transferStatus-based marking
      // and the legacy status-only marking (a pre-2026 transfer had no
      // transferStatus field at all — see claim-transferred-dogs.js's
      // own comment on the same legacy shape). Once a buyer actually
      // claims a dog, status/transferStatus reset to their own "clean"
      // active state and the now-current owner regains full delete
      // rights over what is now genuinely their own dog.
      allow delete: if isSignedIn() && resource.data.currentOwnerId == request.auth.uid &&
        resource.data.get('status', 'active') != 'transferred' &&
        resource.data.get('transferStatus', null) != 'pendingClaim';

      // Creator becomes tenantId/currentOwnerId/createdByUserId — a client
      // cannot assign ownership to anyone else at creation time either
      // (createDog() always derives all three from the authenticated uid).
      // dateOfBirth must be a validly-shaped YYYY-MM-DD string on create —
      // both existing callers (DogNewPage's form, LittersPage's
      // litter-puppy flow) already enforce this via parseDobStrict at the
      // UI layer; this closes the gap for any future caller and
      // specifically stops a litter puppy ever being created with an
      // empty/malformed dateOfBirth. Format-only (see isValidDobString) —
      // rejecting a future-dated or age-implausible DOB stays a
      // client+service-layer concern, since rules have no generic date
      // arithmetic to check that with.
      allow create: if isSignedIn() &&
        request.resource.data.tenantId == request.auth.uid &&
        request.resource.data.currentOwnerId == request.auth.uid &&
        request.resource.data.createdByUserId == request.auth.uid &&
        isValidDobString(request.resource.data.dateOfBirth);
    }

    // ── passportReservations/{passportId} — uniqueness index for
    // Dog.passportId (ADR-002 Phase C1). Document ID IS the passportId
    // being claimed; existence alone is the uniqueness signal, so no
    // client ever needs to read another user's reservation for the
    // create flow to work correctly (the transaction in
    // reservePassportId() checks existence via a read permitted here).
    // Permanent once created — never updated or deleted, since a
    // passportId must never be reassigned or freed for reuse.
    match /passportReservations/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if false;
    }

    // ── Records keyed by dogId — access follows the parent dog's ownership ──
    match /vaccineRecords/{id} {
      allow read, update, delete: if dogBelongsToUser(resource.data.dogId);
      allow create: if dogBelongsToUser(request.resource.data.dogId);
    }
    match /wormingRecords/{id} {
      allow read, update, delete: if dogBelongsToUser(resource.data.dogId);
      allow create: if dogBelongsToUser(request.resource.data.dogId);
    }
    match /healthTests/{id} {
      allow read, update, delete: if dogBelongsToUser(resource.data.dogId);
      allow create: if dogBelongsToUser(request.resource.data.dogId);
    }
    match /activityNotes/{id} {
      allow read, update, delete: if dogBelongsToUser(resource.data.dogId);
      allow create: if dogBelongsToUser(request.resource.data.dogId);
    }

    // ── heatCycles — read/delete use the same dogBelongsToUser access
    // pattern as the other dogId-keyed records above (no age check
    // needed for either, so they stay client-side). create/update both
    // require verifying the Dam and/or Sire "meets actual minimum
    // breeding maturity", which needs real date arithmetic Firestore
    // Rules has no functions for — both now happen exclusively through
    // api/save-heat-cycle.js (Admin SDK, full validation via
    // _lib/parent-eligibility.js). Direct client create/update is
    // denied outright (Codex round 3, Blocker 1).
    match /heatCycles/{id} {
      allow read, delete: if dogBelongsToUser(resource.data.dogId);
      allow create, update: if false;
    }

    // ── documents — access follows the parent dog's ownership, same as
    // vaccineRecords/healthTests/activityNotes, so a claimed dog's
    // pre-transfer documents stay visible to its new current owner. (A
    // plain tenantId-literal rule here previously also broke
    // getDogDocuments()'s dogId-only list query outright — Firestore
    // denies a `list` query up front when its only where-clause doesn't
    // match a literal field the rule compares against; a get()-based rule
    // like dogBelongsToUser doesn't have that restriction.) ──
    match /documents/{id} {
      allow read, update, delete: if dogBelongsToUser(resource.data.dogId);
      allow create: if dogBelongsToUser(request.resource.data.dogId);
    }
    // NOTE: get and list are split (rather than a combined `read`) so that
    // an existence-check on a not-yet-created reminder (e.g.
    // upsertVaccineReminder()'s dedupe check before its first-ever write)
    // doesn't get denied — `resource == null` for a get on a missing doc,
    // and dereferencing resource.data on null previously errored out the
    // whole rule, which Firestore treats as a deny. A missing document
    // still exposes no data either way. `list` keeps the stricter
    // tenantId-only check since query results always have real data.
    match /reminders/{id} {
      allow get: if isSignedIn()
        && (resource == null || resource.data.tenantId == request.auth.uid);

      allow list: if isSignedIn()
        && resource.data.tenantId == request.auth.uid;

      allow create: if isSignedIn()
        && request.resource.data.tenantId == request.auth.uid;

      allow update, delete: if isSignedIn()
        && resource.data.tenantId == request.auth.uid;
    }
    // damId is validated on create (never editable afterwards — see
    // updateLitter()'s callers, which only ever touch name/dates/notes/
    // puppyIds) so a stale/wrong-tenant/transferred Dam can't be
    // submitted even if the client's own selector was bypassed.
    match /litters/{id} {
      allow read, delete: if isSignedIn() && resource.data.tenantId == request.auth.uid;
      // Codex round 3, Blocker 1: create requires verifying the Dam (and
      // Sire, if set) "meets actual minimum breeding maturity", which
      // needs real date arithmetic Firestore Rules can't do — create now
      // happens exclusively through api/create-litter.js (Admin SDK,
      // full validation via _lib/parent-eligibility.js). Direct client
      // create is denied outright.
      allow create: if false;
      // A litter with puppies attached must keep a validly-shaped
      // actualBirthDate — mirrors the same invariant enforced when
      // puppies are added in the first place (dogs/{dogId}'s create
      // rule requires a validly-shaped dateOfBirth, which for a litter
      // puppy always comes from the litter's actualBirthDate).
      //
      // tenantId/damId/sireId stay immutable on update (defense in depth
      // — create's own move to a server endpoint already prevents a
      // fresh unvalidated damId/sireId from ever being set, but this
      // still blocks repointing an ALREADY-validated reference post
      // creation, and blocks reassigning the litter to a different
      // tenant). The app UI never exposes a way to edit any of these
      // after creation anyway (editLitterForm only ever touches name/
      // dates/notes/actualBirthDate).
      allow update: if isSignedIn() && resource.data.tenantId == request.auth.uid &&
        request.resource.data.tenantId == resource.data.tenantId &&
        request.resource.data.damId == resource.data.damId &&
        request.resource.data.get('sireId', null) == resource.data.get('sireId', null) &&
        (request.resource.data.get('puppyIds', []).size() == 0 ||
         isValidDobString(request.resource.data.get('actualBirthDate', null)));
    }

    // ── auditLogs — append-only, never editable/deletable by clients ──
    match /auditLogs/{id} {
      allow read: if isSignedIn() && resource.data.tenantId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.tenantId == request.auth.uid;
      allow update, delete: if false;
    }

    // ── scanLogs — written whenever ANYONE scans a public QR passport, so
    // create must stay open to unauthenticated requests. But scan logs
    // should never be readable, editable, or deletable by clients (only via
    // Admin SDK / a server route, if you ever need to show scan history to
    // the breeder) — otherwise this becomes a stalking/tracking leak.
    match /scanLogs/{id} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    // ── Deny everything else by default ──
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
