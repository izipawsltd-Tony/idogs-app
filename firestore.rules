rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwnerUser(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // A dog "belongs to" whoever is its breeder (tenantId) or its current
    // owner (currentOwnerId) — both should be able to see/manage it.
    function dogBelongsToUser(dogId) {
      let dog = get(/databases/$(database)/documents/dogs/$(dogId)).data;
      return isSignedIn() &&
        (dog.tenantId == request.auth.uid || dog.currentOwnerId == request.auth.uid);
    }

    // A Sire reference (heatCycles.sireId) is only valid if it currently
    // points at a living male dog under the requesting breeder's own
    // ACTIVE control — currentOwnerId specifically, not tenantId. A dog
    // the breeder originally issued but has since transferred away must
    // never be selectable as a Sire again, even though tenantId still
    // matches (tenantId is permanent provenance, used elsewhere in this
    // file for historical read access — not an ongoing control signal).
    // A referenced breeding-role dog (Sire or Dam) is only valid if it
    // currently points at a living dog of the required sex, under the
    // requesting breeder's own ACTIVE control (currentOwnerId, not
    // tenantId — see isEligibleSire's original comment: a dog the
    // breeder issued but has since transferred away must never be
    // selectable again, even though tenantId still matches).
    function isEligibleBreedingDog(dogId, requiredSex) {
      let candidate = get(/databases/$(database)/documents/dogs/$(dogId)).data;
      return exists(/databases/$(database)/documents/dogs/$(dogId)) &&
        candidate.sex == requiredSex &&
        candidate.currentOwnerId == request.auth.uid &&
        candidate.get('isDeceased', false) == false;
    }
    function isEligibleSire(sireId) {
      return isEligibleBreedingDog(sireId, 'male');
    }
    function isEligibleDam(damId) {
      return isEligibleBreedingDog(damId, 'female');
    }

    // sireId is optional — a manually-entered external sire has no
    // sireId at all. Only validate it when the caller actually set one,
    // so a wrong-tenant/transferred/deleted/malformed sireId is rejected
    // independently of whatever the client's own dropdown happened to
    // show (which may be stale by the time Save is clicked).
    function heatCycleSireValid(data) {
      return !('sireId' in data) || data.sireId == null || isEligibleSire(data.sireId);
    }

    // ── users/{uid} — only the account owner can read/write their own profile ──
    match /users/{userId} {
      allow read, write: if isOwnerUser(userId);
    }

    // ── dogs/{dogId} ──
    // NOTE: if there is a public QR "passport" view of a dog (scan a QR code
    // to see public-safe details without logging in), this rule will BREAK
    // it, because read now requires being the tenant or current owner.
    // Public passport viewing needs to go through a server API route (using
    // Admin SDK, which bypasses these rules) that returns only the fields
    // allowed by PassportVisibility — never a direct client-side Firestore
    // read of the full dog document. Flag this before deploying if such a
    // page exists.
    match /dogs/{dogId} {
      allow read: if isSignedIn() &&
        (resource.data.tenantId == request.auth.uid || resource.data.currentOwnerId == request.auth.uid);

      // Only the CURRENT owner may write — not the former breeder once a
      // claim has moved currentOwnerId elsewhere (tenantId is permanent
      // provenance for *read*, not an ongoing management right). Verified
      // safe: transferDogOwnership() is only ever called while the caller
      // still IS currentOwnerId (currentOwnerId only changes via the
      // server-side claim route), so no legitimate flow needs tenantId-only
      // write access. Also never reassigns tenantId/currentOwnerId/
      // createdByUserId/sourceType — those are immutable via any client
      // write, changed only by the Admin SDK claim route, which bypasses
      // these rules entirely.
      allow update: if isSignedIn() &&
        resource.data.currentOwnerId == request.auth.uid &&
        request.resource.data.tenantId == resource.data.tenantId &&
        request.resource.data.currentOwnerId == resource.data.currentOwnerId &&
        request.resource.data.createdByUserId == resource.data.createdByUserId &&
        request.resource.data.sourceType == resource.data.sourceType;

      allow delete: if isSignedIn() && resource.data.currentOwnerId == request.auth.uid;

      // Creator becomes tenantId/currentOwnerId/createdByUserId — a client
      // cannot assign ownership to anyone else at creation time either
      // (createDog() always derives all three from the authenticated uid).
      allow create: if isSignedIn() &&
        request.resource.data.tenantId == request.auth.uid &&
        request.resource.data.currentOwnerId == request.auth.uid &&
        request.resource.data.createdByUserId == request.auth.uid;
    }

    // ── passportReservations/{passportId} — uniqueness index for
    // Dog.passportId (ADR-002 Phase C1). Document ID IS the passportId
    // being claimed; existence alone is the uniqueness signal, so no
    // client ever needs to read another user's reservation for the
    // create flow to work correctly (the transaction in
    // reservePassportId() checks existence via a read permitted here).
    // Permanent once created — never updated or deleted, since a
    // passportId must never be reassigned or freed for reuse.
    match /passportReservations/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if false;
    }

    // ── Records keyed by dogId — access follows the parent dog's ownership ──
    match /vaccineRecords/{id} {
      allow read, update, delete: if dogBelongsToUser(resource.data.dogId);
      allow create: if dogBelongsToUser(request.resource.data.dogId);
    }
    match /wormingRecords/{id} {
      allow read, update, delete: if dogBelongsToUser(resource.data.dogId);
      allow create: if dogBelongsToUser(request.resource.data.dogId);
    }
    match /healthTests/{id} {
      allow read, update, delete: if dogBelongsToUser(resource.data.dogId);
      allow create: if dogBelongsToUser(request.resource.data.dogId);
    }
    match /activityNotes/{id} {
      allow read, update, delete: if dogBelongsToUser(resource.data.dogId);
      allow create: if dogBelongsToUser(request.resource.data.dogId);
    }

    // ── heatCycles — same dogBelongsToUser access pattern as the other
    // dogId-keyed records above. Previously had NO rule at all here, so
    // every read/write fell through to the default-deny block at the
    // bottom of this file: the Heat Cycle Records list silently loaded
    // empty and "Add Heat Cycle" always failed with a generic error.
    // create/update are additionally scoped: the target dog must be
    // female (Dam-only — a male or unrelated-tenant dog must never
    // receive one even if a client bypasses the UI's own eligibility
    // gating), and any sireId set on the record must independently
    // resolve to a currently-eligible Sire (see heatCycleSireValid) —
    // never trusted from whatever the client's dropdown last showed.
    match /heatCycles/{id} {
      allow read, delete: if dogBelongsToUser(resource.data.dogId);
      allow create: if dogBelongsToUser(request.resource.data.dogId) &&
        get(/databases/$(database)/documents/dogs/$(request.resource.data.dogId)).data.sex == 'female' &&
        heatCycleSireValid(request.resource.data);
      allow update: if dogBelongsToUser(resource.data.dogId) &&
        heatCycleSireValid(request.resource.data);
    }

    // ── documents — access follows the parent dog's ownership, same as
    // vaccineRecords/healthTests/activityNotes, so a claimed dog's
    // pre-transfer documents stay visible to its new current owner. (A
    // plain tenantId-literal rule here previously also broke
    // getDogDocuments()'s dogId-only list query outright — Firestore
    // denies a `list` query up front when its only where-clause doesn't
    // match a literal field the rule compares against; a get()-based rule
    // like dogBelongsToUser doesn't have that restriction.) ──
    match /documents/{id} {
      allow read, update, delete: if dogBelongsToUser(resource.data.dogId);
      allow create: if dogBelongsToUser(request.resource.data.dogId);
    }
    // NOTE: get and list are split (rather than a combined `read`) so that
    // an existence-check on a not-yet-created reminder (e.g.
    // upsertVaccineReminder()'s dedupe check before its first-ever write)
    // doesn't get denied — `resource == null` for a get on a missing doc,
    // and dereferencing resource.data on null previously errored out the
    // whole rule, which Firestore treats as a deny. A missing document
    // still exposes no data either way. `list` keeps the stricter
    // tenantId-only check since query results always have real data.
    match /reminders/{id} {
      allow get: if isSignedIn()
        && (resource == null || resource.data.tenantId == request.auth.uid);

      allow list: if isSignedIn()
        && resource.data.tenantId == request.auth.uid;

      allow create: if isSignedIn()
        && request.resource.data.tenantId == request.auth.uid;

      allow update, delete: if isSignedIn()
        && resource.data.tenantId == request.auth.uid;
    }
    // damId is validated on create (never editable afterwards — see
    // updateLitter()'s callers, which only ever touch name/dates/notes/
    // puppyIds) so a stale/wrong-tenant/transferred Dam can't be
    // submitted even if the client's own selector was bypassed.
    match /litters/{id} {
      allow read, update, delete: if isSignedIn() && resource.data.tenantId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.tenantId == request.auth.uid &&
        isEligibleDam(request.resource.data.damId);
    }

    // ── auditLogs — append-only, never editable/deletable by clients ──
    match /auditLogs/{id} {
      allow read: if isSignedIn() && resource.data.tenantId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.tenantId == request.auth.uid;
      allow update, delete: if false;
    }

    // ── scanLogs — written whenever ANYONE scans a public QR passport, so
    // create must stay open to unauthenticated requests. But scan logs
    // should never be readable, editable, or deletable by clients (only via
    // Admin SDK / a server route, if you ever need to show scan history to
    // the breeder) — otherwise this becomes a stalking/tracking leak.
    match /scanLogs/{id} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    // ── Deny everything else by default ──
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
